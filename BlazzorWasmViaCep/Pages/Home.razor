@page "/"
@using BlazzorWasmViaCep.Models
@inject HttpClient Http;


<PageTitle>Consulta do CEP</PageTitle>

<h1>Consulta Via CEP</h1>

<div class="form-group">
    <label for="cepInput">
        CEP: 
    </label>
    <input type="text" class="form-control" id="cepInput" @bind="cep" placeholder="Digite o CEP: (somente números)" />
</div>
<button class="btn btn-primary mt-2" @onclick="ConsultarCep">
    Consultar
</button>

@if(viaCepResponse != null)
{
    <h3 class="mt-4">
        Resultado: 
    </h3>
    <table class="table table-bordered">
        <tbody>
            <tr>
                <td>
                    <strong>CEP:</strong>
                </td>
                <td>
                    @viaCepResponse.Cep
                </td>
            </tr>
            <tr>
                <td>
                    <strong>Rua:</strong>
                </td>
                <td>
                    @viaCepResponse.Rua
                </td>
            </tr>            
            <tr>
                <td>
                    <strong>Bairro:</strong>                    
                </td>
                <td>
                    @viaCepResponse.bairro
                </td>
            </tr>
            <tr>
                <td>
                    <strong>Localidade:</strong>                    
                </td>
                <td>
                    @viaCepResponse.Cidade
                </td>
            </tr>
            <tr>
                <td>
                    <strong>Região:</strong>
                </td>
                <td>
                    @viaCepResponse.Regiao
                </td>
            </tr>
            <tr>
                <td>
                    <strong>Uf:</strong>                    
                </td>
                <td>
                    @viaCepResponse.Uf
                </td>
            </tr>
            <tr>
                <td>
                    <strong>DDD:</strong>                    
                </td>
                <td>
                    @viaCepResponse.Ddd
                </td>
            </tr>

        </tbody>
    </table>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-4">
        @errorMessage
    </div>
}


@code{
    string cep;
    Endereco viaCepResponse;
    string errorMessage;

    private async Task ConsultarCep()
    {
        viaCepResponse = null;
        errorMessage = string.Empty;

        if (string.IsNullOrEmpty(cep))
        {
            errorMessage = "Por favor, digite um cep.";
            return;
        }
        string CepFormatado = new string(cep.Where(char.IsDigit).ToArray());

        if(CepFormatado.Length != 8)
        {
            errorMessage = "O Cep deve conter 8 digitos.";
            return;
        }

        try
        {
            var url = $"https://viacep.com.br/ws/{CepFormatado}/json/";

            viaCepResponse = await Http.GetFromJsonAsync<Endereco>(url);

            if(viaCepResponse.Cep == null)
            {
                errorMessage = "Cep não encontrado ou inválido!";
                viaCepResponse = null;
            }


        }
        catch(HttpRequestException ex)
        {
            errorMessage = $"Erro ao conectar á API: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Ocorreu um erro: {ex.Message}";
        }
    }
}